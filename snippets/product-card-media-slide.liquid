{%- doc -%}
  Single slide within the product card image strip.

  @param {object} [image] - preview_image to render; renders placeholder if blank
  @param {number} index - swatch index used for data-swatch-index attribute
  @param {string} loading - eager | lazy
  @param {object} product
{%- enddoc -%}

<div
  class="pcard__image-slide tw:relative tw:h-full tw:min-w-full tw:flex-shrink-0 tw:snap-start tw:snap-always tw:overflow-hidden"
  data-swatch-index="{{ index }}"
>
  {% if image != blank %}
    {% render 'product-card-media-image', image: image, product: product, loading: loading %}
  {% else %}
    <span
      class="tw:absolute tw:inset-0 tw:flex tw:items-center tw:justify-center"
      aria-hidden="true"
    >
      {{ 'product-1' | placeholder_svg_tag: 'tw:h-full tw:w-full tw:object-contain tw:p-4 tw:text-neutral-300' }}
    </span>
  {% endif %}
</div>

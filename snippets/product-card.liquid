{%- doc -%}
  @param {object} product - The product object
  @param {object} [block] - Optional block object for attributes
  @param {number} [image_ratio] - Padding-bottom percentage for aspect ratio (default: 110)
  @param {boolean} [show_title] - Show product title (default: true)
  @param {boolean} [show_price] - Show product price (default: true)
  @param {boolean} [show_vendor] - Show product vendor (default: false)
  @param {boolean} [show_swatches] - Show color swatches (default: true)
  @param {number} [max_swatches] - Max number of swatches to show before overflow (default: 6)
{%- enddoc -%}

{% liquid
  assign variant = product.selected_or_first_available_variant
  assign on_sale = false
  if variant.compare_at_price > variant.price
    assign on_sale = true
  endif

  assign initial_image = null
  assign initial_hover = null
  assign product_has_swatches = false

  for product_option in product.options_with_values
    for option_value in product_option.values
      unless product_has_swatches
        if option_value.swatch
          assign product_has_swatches = true
          assign first_swatch_variant = option_value.variant

          assign initial_image = first_swatch_variant.featured_media.preview_image
          if initial_image == blank and first_swatch_variant.product.featured_media != blank
            assign initial_image = first_swatch_variant.product.featured_media.preview_image
          endif

          assign first_color_name = option_value.name
          assign first_color_handle = first_color_name | handleize
          assign first_primary_id = first_swatch_variant.featured_media.id

          for media in product.media
            if media.id != first_primary_id and media.media_type == 'image'
              if media.alt == first_color_name
                assign initial_hover = media.preview_image
                break
              elsif initial_hover == null
                assign src_handle = media.src | handleize
                if src_handle contains first_color_handle
                  assign initial_hover = media.preview_image
                endif
              endif
            endif
          endfor
        endif
      endunless
    endfor
  endfor

  if initial_image == blank
    assign initial_image = product.featured_image
  endif

  assign show_content = false
  if show_title != false or show_price != false or show_vendor != false or show_swatches != false
    assign show_content = true
  endif
%}

<p-card
  class="pcard tw:font-sans"
  {% if block %}
    {{- block.shopify_attributes -}}
  {% endif %}
>
  {% render 'product-card-media',
    product: product,
    initial_image: initial_image,
    initial_hover: initial_hover,
    variant: variant,
    image_ratio: image_ratio
  %}

  {% if show_content %}
    <div class="pcard__content">
      {% if product_has_swatches and show_swatches != false %}
        {% render 'product-card-swatches', product: product, max_swatches: max_swatches %}
      {% endif %}

      <div class="pcard__body">
        {% if show_vendor != false and product.vendor != blank %}
          <p
            class="tw:text-sm tw:text-product-foreground tw:line-clamp-1 tw:capitalize"
            title="{{ product.vendor | escape }}"
          >
            {{ product.vendor }}
          </p>
        {% endif %}

        {% if show_title != false %}
          <h3 class="tw:w-fit">
            <a class="pcard__title tw:!text-base tw:!text-product-accent" href="{{ product.url }}">
              {{ product.title }}
            </a>
          </h3>
        {% endif %}

        {% if show_price != false %}
          <div class="pcard__price-row">
            <span
              class="pcard__compare-price tw:text-sm tw:text-product-foreground tw:line-through"
              {% unless on_sale %}
                hidden
              {% endunless %}
            >
              {{ variant.compare_at_price | money }}
            </span>
            <span class="pcard__price tw:text-sm tw:text-product-foreground">
              {{ variant.price | money }}
            </span>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</p-card>

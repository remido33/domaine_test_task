{% liquid
  assign product = closest.product
-%}

{% render 'product-card',
  product: product,
  show_title: block.settings.show_title,
  show_price: block.settings.show_price,
  show_vendor: block.settings.show_vendor,
  show_swatches: block.settings.show_swatches,
  max_swatches: block.settings.max_swatches,
  image_ratio: block.settings.image_ratio
%}
{% render 'buy-buttons-styles' %}
{% render 'gift-card-recipient-form-styles' %}
{% render 'quick-add-styles' %}
{% render 'quick-add-modal-styles' %}
{% render 'product-badges-styles' %}

{% schema %}
{
  "name": "t:names.product_card",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_card"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_ratio",
      "label": "Aspect ratio",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 110
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "range",
      "id": "max_swatches",
      "label": "Max swatches",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 6,
      "visible_if": "{{ block.settings.show_swatches }}"
    }
  ]
}
{% endschema %}
